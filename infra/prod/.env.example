# Copy to .env on the server: cp .env.example .env && nano .env

# Your domain (DNS A records must point to the server IP)
DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-generate-a-long-random-string
DEBUG=false

POSTGRES_PASSWORD=change-me-strong-postgres-password
DATABASE_URL=postgresql+asyncpg://sport:change-me-strong-postgres-password@postgres:5432/sport_app
REDIS_URL=redis://redis:6379/0

# CORS: allow all app subdomains over HTTPS
CORS_ALLOW_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?example\.com$

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=change-me-minio-secret
S3_BUCKET=sport-app
