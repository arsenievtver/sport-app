# Copy to .env on the server: cp .env.example .env && nano .env

DOMAIN=athlete-app.ru
LETSENCRYPT_EMAIL=admin@athlete-app.ru

# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-generate-a-long-random-string
DEBUG=false

POSTGRES_PASSWORD=change-me-strong-postgres-password
DATABASE_URL=postgresql+asyncpg://sport:change-me-strong-postgres-password@postgres:5432/sport_app
REDIS_URL=redis://redis:6379/0

CORS_ALLOW_ORIGIN_REGEX='^https://([a-z0-9-]+\.)?athlete-app\.ru$'

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=change-me-minio-secret
S3_BUCKET=sport-app

# WHOOP (https://developer.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://my.athlete-app.ru/api/v1/integrations/whoop/callback
ATHLETE_APP_URL=https://my.athlete-app.ru

# LogMeal (https://docs.logmeal.com) — имена как в кабинете logmeal.com
# APICompanyToken — ключ компании (⚫ admin)
LOGMEAL_API_COMPANY_TOKEN=
# APIUserToken — токен APIUser (🔴), напр. для APIUser_Alex_19
LOGMEAL_API_USER_TOKEN=
LOGMEAL_LANGUAGE=eng

# Yandex Cloud Translate — русские названия блюд LogMeal
YANDEX_TRANSLATE_API_KEY=
YANDEX_TRANSLATE_FOLDER_ID=

# Yandex Foundation Models — embeddings + draft workout from text
# Scope: yc.ai.foundationModels.execute (falls back to TRANSLATE_* if unset)
# YANDEX_AI_API_KEY=
# YANDEX_AI_FOLDER_ID=
# After deploy + migrate: docker compose exec api python scripts/backfill_activity_embeddings.py
