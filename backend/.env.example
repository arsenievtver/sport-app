DEBUG=true
DATABASE_URL=postgresql+asyncpg://sport:sport@localhost:5433/sport_app
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=dev-secret-change-in-production

# Host port for Docker Postgres (5432 is often busy on macOS)
POSTGRES_HOST_PORT=5433

# Production: comma-separated origins or use CORS_ALLOW_ORIGIN_REGEX
# CORS_ALLOW_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?athlete-app\.ru$

# WHOOP integration (https://developer.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/api/v1/integrations/whoop/callback
ATHLETE_APP_URL=http://localhost:5173

# LogMeal (https://docs.logmeal.com) — имена как в кабинете logmeal.com
# APICompanyToken — ключ компании (⚫ admin), нужен для auto-signup APIUser
LOGMEAL_API_COMPANY_TOKEN=
# APIUserToken — токен пользователя APIUser_Alex_19 и т.п. (🔴), для распознавания фото
LOGMEAL_API_USER_TOKEN=
LOGMEAL_LANGUAGE=eng

# Yandex Cloud Translate — русские названия блюд LogMeal (https://cloud.yandex.ru/docs/translate/)
YANDEX_TRANSLATE_API_KEY=
YANDEX_TRANSLATE_FOLDER_ID=
# FOOD_TRANSLATION_SOURCE_LANG=en
# FOOD_TRANSLATION_TARGET_LANG=ru

# Yandex Foundation Models — embeddings + draft-from-text (YandexGPT)
# Key needs scope yc.ai.foundationModels.execute. Falls back to TRANSLATE_* if unset.
# YANDEX_AI_API_KEY=
# YANDEX_AI_FOLDER_ID=
# YANDEX_GPT_MODEL=yandexgpt-lite/latest
# After migrate: python scripts/backfill_activity_embeddings.py
